# MyTube - Configurações de Ambiente
# IMPORTANTE: Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA versione o arquivo .env no Git!

# === DATABASE ===
DB_HOST=localhost
DB_NAME=mytube_db
DB_USER=root
DB_PASS=

# === SITE ===
SITE_URL=http://localhost/mytube
SITE_NAME=MyTube
APP_ENV=development
# APP_ENV: 'development' ou 'production'
# Em produção: força HTTPS, ativa cookie Secure, headers de segurança

# === CHAT SERVER ===
CHAT_SERVER_URL=http://localhost:3001
# Em produção: http://127.0.0.1:3001 (se na mesma máquina) ou http://ip-interno:3001

# === CLOUDFLARE R2 / AWS S3 ===
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
R2_BUCKET=mytube
R2_PUBLIC_URL=https://pub-xyz.r2.dev

# === EMAIL (SMTP) ===
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-app-password-aqui
MAIL_FROM_EMAIL=seu-email@gmail.com
MAIL_FROM_NAME=MyTube

# === SECURITY ===
# Execute: openssl rand -hex 32
CRON_SECRET=gere-um-secret-aleatorio-de-64-caracteres-aqui
JWT_SECRET=gere-outro-secret-aleatorio-de-64-caracteres-aqui

# === SESSION ===
SESSION_LIFETIME=7200
# Tempo de vida da sessão em segundos (7200 = 2 horas)

# === GOOGLE OAUTH ===
# Obter em: https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client IDs
# Adicionar em Authorized JavaScript origins:
#   https://www.mytube.social
#   http://localhost
GOOGLE_CLIENT_ID=SEU_CLIENT_ID_AQUI.apps.googleusercontent.com
