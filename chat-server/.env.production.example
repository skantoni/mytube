# ============================================================
# MyTube Chat Server — Variáveis de Ambiente PRODUÇÃO
# ============================================================
# INSTRUÇÕES:
#   1. Copiar este ficheiro: cp .env.example .env.production
#   2. Preencher TODOS os valores marcados com <ALTERAR>
#   3. NUNCA fazer commit do .env.production (está no .gitignore)
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Base de Dados MySQL ───────────────────────────────────────
DB_HOST=127.0.0.1
DB_USER=<ALTERAR: utilizador_mysql_producao>
DB_PASSWORD=<ALTERAR: password_mysql_muito_segura>
DB_NAME=mytube_db
DB_PORT=3306

# ── CORS — domínio do teu site em produção ────────────────────
# Exemplo: CORS_ORIGIN=https://www.mytube.ao
CORS_ORIGIN=<ALTERAR: https://www.teu-dominio.com>

# ── Segurança ─────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=<ALTERAR: string-aleatoria-muito-longa-minimo-64-chars>

# ── Logs ──────────────────────────────────────────────────────
# Nível: error | warn | info | debug (usar 'warn' em produção)
LOG_LEVEL=warn
